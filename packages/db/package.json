{
  "name": "@openscore/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "prisma validate --config prisma.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "db:format": "prisma format --config prisma.config.ts",
    "db:validate": "prisma validate --config prisma.config.ts",
    "db:generate": "prisma generate --config prisma.config.ts"
  },
  "dependencies": {
    "@prisma/client": "^7.0.0"
  },
  "devDependencies": {
    "prisma": "^7.0.0"
  }
}
