# OpenScore environment template
# Copy this file to .env for local development.

# Runtime
NODE_ENV=development

# Public URLs
WEB_PUBLIC_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://openscore:openscore@localhost:5432/openscore?schema=public

# Cache
REDIS_URL=redis://localhost:6379

# Sports data provider
SPORTS_PROVIDER=mock
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITIONS=PL
THESPORTSDB_API_KEY=
OPENLIGADB_BASE_URL=https://www.openligadb.de/api

# AI provider
AI_PROVIDER=disabled
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=

# Sync behavior
LIVE_SYNC_INTERVAL_SECONDS=60
FIXTURE_SYNC_INTERVAL_MINUTES=15
