{
  "name": "@openscore/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "@openscore/config": "workspace:*",
    "@openscore/db": "workspace:*",
    "@openscore/domain": "workspace:*",
    "@openscore/providers": "workspace:*",
    "hono": "^4.10.0",
    "redis": "^6.0.1"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "tsx": "^4.21.0"
  }
}
