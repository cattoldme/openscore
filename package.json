{
  "name": "openscore",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @openscore/api --filter @openscore/web dev",
    "dev:web": "pnpm --filter @openscore/web dev",
    "dev:api": "pnpm --filter @openscore/api dev",
    "build": "pnpm -r build",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:web": "node scripts/smoke-web.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:format": "pnpm --filter @openscore/db db:format",
    "db:validate": "pnpm --filter @openscore/db db:validate",
    "db:generate": "pnpm --filter @openscore/db db:generate",
    "db:migrate": "pnpm --filter @openscore/db db:migrate",
    "db:seed": "pnpm --filter @openscore/db db:seed",
    "db:seed:dry-run": "pnpm --filter @openscore/db db:seed:dry-run",
    "db:push": "pnpm --filter @openscore/db db:push"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
